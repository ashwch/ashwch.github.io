---
/**
 * Homepage.
 *
 * LAYOUT STRATEGY
 *
 * The page has three clear zones, top to bottom:
 *
 *   1. Hero        — split layout: text column + rotating photography gallery.
 *                    The image gets ~60 % of the width so the photo leads.
 *
 *   2. Writing     — latest two articles as cards.
 *
 *   3. Projects    — the two featured projects (Microverse, auto-uv-env).
 *                    The full credibility layer lives on /pages/projects.html.
 *
 * WHY NO PHOTOGRAPHY STRIP
 *
 * We removed the separate "Photography · Gallery" section below the fold.
 * The hero gallery already links directly to /pages/photography.html and
 * carries more emotional weight than three small Unsplash cards ever could.
 * Removing the duplicate strip makes the page cleaner and respects the photos.
 */

import ArticleCard from '../components/ArticleCard.astro';
import HomepageHeroGallery from '../components/HomepageHeroGallery.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { homepageBanners } from '../data/homepageBanners';
import { featuredProjects } from '../data/projects';
import { getAllArticles } from '../lib/content';

const articles = await getAllArticles();
const latestArticles = articles.slice(0, 2);
---

<BaseLayout canonical="https://ashwch.com/">
  <section class="hero hero-home">
    <div class="container hero--split hero-home__grid">
      <div class="hero-home__copy">
        <span class="eyebrow">Ashwini Chaudhary (Monty)</span>
        <h1 class="display-title">Software, writing, and photography.</h1>
        <p class="hero-copy">
          I lead engineering teams, build software, and write about the systems and tools behind the work.
        </p>
        <div class="hero-actions">
          <a class="button" href="/writing.html">Writing</a>
          <a class="button--secondary" href="/pages/projects.html">Projects</a>
        </div>
      </div>

      <div class="hero-home__visual">
        <HomepageHeroGallery banners={homepageBanners} />
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Writing</h2>
        <a class="section-link" href="/writing.html">View all</a>
      </div>

      <div class="grid grid--two">
        {latestArticles.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Projects</h2>
        <a class="section-link" href="/pages/projects.html">Project index</a>
      </div>

      <div class="grid grid--two">
        {featuredProjects.map((project) => (
          <article class="project-card">
            <div class="article-card__meta">
              <span class="eyebrow" style="margin:0">{project.category}</span>
            </div>
            <h3>{project.name}</h3>
            <p>{project.description}</p>
            <div class="pill-row" style="margin-top:1rem">
              {project.tags.map((tag) => (
                <span class="pill">{tag}</span>
              ))}
            </div>
            <div class="hero-actions">
              <a class="button" href={project.href} target="_blank" rel="noreferrer">Visit site</a>
              {project.repo && (
                <a class="button--secondary" href={project.repo} target="_blank" rel="noreferrer">
                  Source
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
