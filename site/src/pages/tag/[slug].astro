---
import ArticleListItem from '../../components/ArticleListItem.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllArticles, getTagIndex } from '../../lib/content';

export async function getStaticPaths() {
  const articles = await getAllArticles();
  const tags = getTagIndex(articles);
  return tags.map((tag) => ({
    params: { slug: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props;
---

<BaseLayout
  title={`Tag: ${tag.label}`}
  description={`Articles tagged ${tag.label}.`}
  canonical={`https://ashwch.com/tag/${tag.slug}.html`}
>
  <section class="section">
    <div class="container">
      <h1 class="page-title">Tag: {tag.label}</h1>
      <p class="page-lead">{tag.articles.length} article{tag.articles.length === 1 ? '' : 's'} in this tag.</p>
      <div>
        {tag.articles.map((article) => (
          <ArticleListItem article={article} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
