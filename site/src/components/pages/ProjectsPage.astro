---
/**
 * Projects page.
 *
 * This page has a specific job: show what I build now AND the deeper open-source
 * work that gives context to the "current tools" list.
 *
 * A flat repo list feels dry.  A long narrative belongs on the About page.
 * The Projects page should be scannable proof: here are the current things,
 * and here is the broader body of public work behind them.
 *
 * PAGE STRUCTURE (top to bottom)
 *
 *   1. Current projects
 *      The two featured repos (Microverse, auto-uv-env).
 *      Rendered as large split cards so they carry visual weight.
 *
 *   2. Selected open source and ecosystem work
 *      Four compact cards that group related contributions:
 *        - Python ecosystem (CPython / typeshed / mypy)
 *        - Django and tooling
 *        - Instamojo SDK ecosystem
 *        - Community and talks
 *      Each card has tagged category, description, and clean external links.
 *
 *   3. More tools
 *      A smaller utility grid for personal CLI tools, dotfiles, etc.
 *      These sit in a subtly different background to visually separate them
 *      from the heavier credibility section above.
 *
 * STYLING NOTE
 *
 *   The `projects-page__*` BEM classes tighten the default section/heading
 *   styles so the page feels denser and more editorial than the rest of the
 *   site.  Otherwise the default section formatting reads like a blog archive.
 */

import { featuredProjects, projectHighlights, projects } from '../../data/projects';

const utilityProjects = projects.filter((project) => !project.featured);
---

<section class="hero projects-page__hero">
  <div class="container">
    <span class="eyebrow">Projects</span>
    <h1 class="page-title">Projects</h1>
    <p class="page-lead projects-page__lead">
      Current tools I build, plus selected open source, payments, and community work.
    </p>
  </div>
</section>

<!-- ── Section 1: Current projects ────────────────────────────────────── -->

<section class="section projects-page__section" style="padding-top:0">
  <div class="container">
    <div class="section-header projects-page__section-header">
      <h2 class="section-title projects-page__section-title">Current projects</h2>
    </div>

    <div class="grid grid--two">
      {featuredProjects.map((project) => (
        <article class="project-card projects-page__featured-card">
          <span class="eyebrow">{project.category}</span>
          <h2 class="section-title projects-page__featured-title">{project.name}</h2>
          <p>{project.description}</p>
          <div class="pill-row" style="margin-top:1rem">
            {project.tags.map((tag) => (
              <span class="pill">{tag}</span>
            ))}
          </div>
          <div class="hero-actions">
            <a class="button" href={project.href} target="_blank" rel="noreferrer">Open</a>
            {project.repo && (
              <a class="button--secondary" href={project.repo} target="_blank" rel="noreferrer">
                Source
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ── Section 2: Selected open source and ecosystem work ─────────────── -->

<section class="section projects-page__section" style="padding-top:0">
  <div class="container">
    <div class="section-header projects-page__section-header projects-page__section-header--stacked">
      <div class="projects-page__section-copy-block">
        <h2 class="section-title projects-page__section-title">Selected open source and ecosystem work</h2>
        <p class="projects-page__section-copy">
          Python, tooling, payments, and community work over time.
        </p>
      </div>
    </div>

    <div class="projects-page__highlights-grid">
      {projectHighlights.map((highlight) => (
        <article class="surface-card projects-page__highlight-card">
          <div class="article-card__meta">
            <span class="eyebrow" style="margin:0">{highlight.category}</span>
          </div>
          <h3>{highlight.title}</h3>
          <p>{highlight.description}</p>
          <div class="pill-row" style="margin-top:1rem">
            {highlight.tags.map((tag) => (
              <span class="pill">{tag}</span>
            ))}
          </div>
          <div class="inline-actions projects-page__highlight-links">
            {highlight.links.map((link) => (
              <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ── Section 3: More tools ──────────────────────────────────────────── -->

<section class="section projects-page__section" style="background:color-mix(in srgb, var(--bg-subtle) 65%, transparent)">
  <div class="container">
    <div class="section-header projects-page__section-header">
      <h2 class="section-title projects-page__section-title">More tools</h2>
    </div>

    <div class="grid grid--three">
      {utilityProjects.map((project) => (
        <article class="utility-card surface-card">
          <div class="article-card__meta">
            <span class="eyebrow" style="margin:0">{project.category}</span>
          </div>
          <h3>{project.name}</h3>
          <p>{project.description}</p>
          {project.install && (
            <pre style="margin-top:1rem"><code>{project.install}</code></pre>
          )}
          <div class="pill-row" style="margin-top:1rem">
            {project.tags.map((tag) => (
              <span class="pill">{tag}</span>
            ))}
          </div>
          <div class="inline-actions">
            <a href={project.href} target="_blank" rel="noreferrer">Open</a>
            {project.repo && (
              <a href={project.repo} target="_blank" rel="noreferrer">GitHub</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
